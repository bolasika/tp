@startuml
!include style.puml
skinparam ArrowFontStyle plain

box Logic LOGIC_COLOR_T1
participant ":LogicManager" as LogicManager LOGIC_COLOR
participant ":AddressBookParser" as AddressBookParser LOGIC_COLOR
participant ":DeleteCommandParser" as DeleteCommandParser LOGIC_COLOR
participant "d:DeleteCommand" as DeleteCommand LOGIC_COLOR
participant "<<utility>>\nCommandUtil" as CommandUtil LOGIC_COLOR
end box

box Model MODEL_COLOR_T1
participant ":Model" as Model MODEL_COLOR
end box

[-> LogicManager : execute("delete n/David Ng p/90002222")
activate LogicManager

LogicManager -> AddressBookParser : parseCommand("delete n/David Ng p/90002222")
activate AddressBookParser

AddressBookParser -> DeleteCommandParser : parse(arguments)
activate DeleteCommandParser

create DeleteCommand
DeleteCommandParser -> DeleteCommand
activate DeleteCommand
DeleteCommand --> DeleteCommandParser : d
deactivate DeleteCommand

DeleteCommandParser --> AddressBookParser : d
deactivate DeleteCommandParser
destroy DeleteCommandParser

AddressBookParser --> LogicManager : d
deactivate AddressBookParser

LogicManager -> DeleteCommand : execute(model)
activate DeleteCommand

DeleteCommand -> CommandUtil : targetPerson(model, targetInfo)
activate CommandUtil
CommandUtil --> DeleteCommand : personToDelete
deactivate CommandUtil

DeleteCommand -> Model : isShowingEventsFor(personToDelete)
activate Model
Model --> DeleteCommand : isShowingDeletedPerson
deactivate Model

opt personToDelete has a photo
    DeleteCommand -> CommandUtil : safelyDeletePhoto(model, personToDelete, photo, targetDirectory)
    activate CommandUtil
    CommandUtil --> DeleteCommand
    deactivate CommandUtil
end

DeleteCommand -> Model : deletePerson(personToDelete)
activate Model
Model --> DeleteCommand
deactivate Model

opt deleted person's events are on display
    DeleteCommand -> Model : showNoEvents()
    activate Model
    Model --> DeleteCommand
    deactivate Model
end

DeleteCommand --> LogicManager : result
deactivate DeleteCommand
DeleteCommand -[hidden]-> DeleteCommand
destroy DeleteCommand

[<-- LogicManager
deactivate LogicManager
@enduml
